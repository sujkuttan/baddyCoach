# BaddyCoach Configuration
# Copy this to .env and fill in your values.
# All variables are optional — defaults are defined in settings.py.

# GPU
GPU_ENABLED=false

# API keys
GEMINI_API_KEY=

# Gemini model ID (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Model paths (defaults are relative to project root)
TRACKNET_MODEL_PATH=ckpts/TrackNet_best.pt
INPAINTNET_MODEL_PATH=ckpts/InpaintNet_best.pt
COURT_KPRCNN_MODEL_PATH=ckpts/court_kpRCNN.pth
YOLOV8_MODEL_PATH=
RTMPOSE_MODEL_PATH=ckpts/rtmpose/rtmpose-m_simcc-body7_pt-body7_420e-256x192.onnx
HRNET_MODEL_PATH=ckpts/mmpose/hrnet_w32_coco_256x192.onnx
BST_MODEL_PATH=ckpts/bst/bst_CG_AP.pt

# Pose model: rtmpose, mmpose, or hybrid
POSE_MODEL=rtmpose

# Processing
PROCESSING_FPS=30
COURT_DETECTION_FPS=1
SAMPLE_RATE=0
MAX_VIDEO_LENGTH_SECONDS=3600

# Frame defaults (used when real video resolution is unavailable)
DEFAULT_FRAME_WIDTH=1280
DEFAULT_FRAME_HEIGHT=720

# Hit detection weights & thresholds
HIT_TRAJECTORY_WEIGHT=0.4
HIT_SPEED_WEIGHT=0.3
HIT_PROXIMITY_WEIGHT=0.2
HIT_SWING_WEIGHT=0.1
HIT_CONFIDENCE_THRESHOLD=0.3
HIT_DEDUP_GAP_SECONDS=0.1

# Stroke classification thresholds
STROKE_SMOOTHING_MIN_CONFIDENCE=0.25
STROKE_SMOOTHING_FALLBACK_CONFIDENCE=0.3
STROKE_SMOOTHING_WINDOW=2
STROKE_SMOOTHING_MAJORITY_COUNT=3
STROKE_DEDUP_GAP_SECONDS=0.2

# Attributed player lookback
ATTRIBUTION_LOOKBACK_FRAMES=5

# Rally segmentation thresholds
RALLY_GAP_THRESHOLD=60
RALLY_MIN_SHOTS=3
RALLY_ENDING_GAP_PRIMARY=45
RALLY_ENDING_GAP_HIGH_CONF=25
RALLY_ENDING_GAP_NET=15
RALLY_ENDING_HIGH_CONF_MIN=0.6

# Court corner fallback (proportional to frame dimensions)
COURT_CORNER_MARGIN_X=0.08
COURT_CORNER_TOP_Y=0.28
COURT_CORNER_BOTTOM_Y=0.72

# Footwork analytics
FOOTWORK_JUMP_FILTER_PIXELS=500
FOOTWORK_RECOVERY_THRESHOLD_METERS=0.3
FOOTWORK_RECOVERY_LOOKAHEAD_FRAMES=30
