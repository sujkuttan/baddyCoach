# BaddyCoach Configuration
# Copy this to .env and fill in your values.
# All variables are optional — defaults are defined in settings.py.

# GPU
GPU_ENABLED=false

# API keys
GEMINI_API_KEY=

# Model paths (defaults are relative to project root)
TRACKNET_MODEL_PATH=ckpts/TrackNet_best.pt
INPAINTNET_MODEL_PATH=ckpts/InpaintNet_best.pt
COURT_KPRCNN_MODEL_PATH=ckpts/court_kpRCNN.pth
YOLOV8_MODEL_PATH=
RTMPOSE_MODEL_PATH=ckpts/rtmpose/rtmpose-m_simcc-body7_pt-body7_420e-256x192.onnx
HRNET_MODEL_PATH=ckpts/mmpose/hrnet_w32_coco_256x192.onnx
BST_MODEL_PATH=ckpts/bst/bst_CG_AP.pt

# Pose model: rtmpose, mmpose, or hybrid
POSE_MODEL=rtmpose

# Processing
PROCESSING_FPS=30
COURT_DETECTION_FPS=1
SAMPLE_RATE=0
MAX_VIDEO_LENGTH_SECONDS=3600
